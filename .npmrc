# Segurança e performance
audit=true
audit-level=moderate
fund=false
loglevel=error
save-exact=true
engine-strict=false
legacy-peer-deps=true

# Cache
cache=/tmp/npm-cache
prefer-offline=true

# Registry
registry=https://registry.npmjs.org/

# Timeouts
fetch-retries=3
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=60000
